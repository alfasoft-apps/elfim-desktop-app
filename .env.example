# Laravel REST baza ünvanı (veb layihədəki NEXT_PUBLIC_REST_API_ENDPOINT ilə eyni rol).
# Release builds also use `.env.production` and https://admin.elfim.az/api if unset.
VITE_REST_API_ENDPOINT=https://admin.elfim.az/api

# Yerli inkişaf üçün `.env.development` faylına baxın (Herd):
# VITE_REST_API_ENDPOINT=https://elfim-backend-new.test/api
